{
  "name": "webmux",
  "version": "0.1.0",
  "description": "Webmux - 面向 Agent 的统一网络操作系统",
  "author": "Webmux Team",
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "webmux": "./dist/index.js"
  },
  "scripts": {
    "dev": "node --watch scripts/dev.mjs",
    "build": "tsc && node scripts/build.mjs",
    "start": "node dist/index.js",
    "check-deps": "node scripts/check-deps.mjs",
    "cleanup-ports": "node scripts/cleanup-ports.mjs",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.mjs || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "puppeteer-core": "^24.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "webmux",
    "web-agent",
    "web-agent-plugin",
    "browser-automation",
    "mcp",
    "claude-code",
    "ai-agent",
    "web-scraping",
    "puppeteer",
    "chrome-devtools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/webmux/webmux.git"
  },
  "bugs": {
    "url": "https://github.com/webmux/webmux/issues"
  },
  "homepage": "https://github.com/webmux/webmux#readme",
  "files": [
    "dist",
    "SKILL.md",
    "references",
    "scripts"
  ]
}
